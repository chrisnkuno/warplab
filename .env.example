# WarpLab local environment example
#
# Copy this file to `.env` when you want local CLI helpers to pick up secrets.
# Do not commit your real `.env`.

# Preferred Kaggle auth: modern token from https://www.kaggle.com/settings
KAGGLE_API_TOKEN=your-kaggle-api-token

# Optional legacy Kaggle auth fallback.
# Only needed if you use kaggle.json-style credentials instead of the token flow.
# KAGGLE_USERNAME=your-kaggle-username
# KAGGLE_KEY=your-kaggle-legacy-api-key
